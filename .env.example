# Copier ce fichier en .env et remplir les valeurs
# Ne jamais committer le fichier .env (deja dans .gitignore)

# Cle API Anthropic (obligatoire pour l'analyse et la generation de PV)
# Obtenir sur : https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-VOTRE_CLE_ICI

# Token HuggingFace (requis uniquement pour la diarization — identification des locuteurs)
# Obtenir sur : https://huggingface.co/settings/tokens
# Accepter les CGU sur : https://huggingface.co/pyannote/speaker-diarization-3.1
HF_TOKEN=hf_VOTRE_TOKEN_ICI
